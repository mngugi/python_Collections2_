   "source": [
    "+ Write a Python program that\n",
    "> +  (a) asks the user for a floating point number `x0`, and prints out the value of `f (x) = x3 − 3x + 1 at x0.`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "05aefae2-ab6d-434e-8eb8-852a21f12d66",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter floating number:  3.0\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "f(3.0) = 19.0\n"
     ]
    }
   ],
   "source": [
    "x0 = float(input(\"Enter floating number: \"))\n",
    "\n",
    "fx = x0**3 - 3*x0 + 1 \n",
    "\n",
    "print(f'f({x0}) = {fx}')"
   ]
  },
